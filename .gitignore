# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# build / output folders
/dist
/out

# misc
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs
*.log

# Env files (already wildcarded, but keep explicit common locals)
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini

# Caches
.cache
.parcel-cache
.next/cache
/.turbo

# bundler / package manager caches
.eslintcache
.swc
.yarn-integrity

# lockfiles that are typically committed are not ignored by default.
# If you use a package manager that creates a lockfile you don't want committed,
# add it here (e.g. package-lock.json, pnpm-lock.yaml) — left commented by default.
.pnpm-debug.log*

# Vercel, Netlify, Firebase and other deploy or platform directories
.vercel
# env files (can opt-in for committing if needed)
.env*

# IDE history/temporary files
.history/

# Local Next/Framework outputs and generated files
.next
.next/*
/.next

# typescript
*.tsbuildinfo
next-env.d.ts
*.pem